{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/session_mode.py\""
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "mcp__.*akeneo.*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/validate_write.py\" \"${CLAUDE_PLUGIN_ROOT}\""
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/validate_write.py\" \"${CLAUDE_PLUGIN_ROOT}\""
          }
        ]
      }
    ]
  }
}
